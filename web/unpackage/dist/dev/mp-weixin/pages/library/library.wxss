/* 页面通用样式 */
page.data-v-b5c5788b {
  box-sizing: border-box;
  min-height: 100vh;
  background-color: #F8F8F8;
}

/* 清除浮动 */
.clearfix.data-v-b5c5788b::after {
  content: "";
  display: table;
  clear: both;
}

/* 单行文字省略 */
.text-ellipsis.data-v-b5c5788b {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 多行文字省略 */
.text-ellipsis-2.data-v-b5c5788b {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Flex布局辅助 */
.flex-center.data-v-b5c5788b {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between.data-v-b5c5788b {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-column.data-v-b5c5788b {
  display: flex;
  flex-direction: column;
}

/* 页面容器 */
.page-container.data-v-b5c5788b {
  padding: 30rpx;
}

/* 卡片样式 */
.card.data-v-b5c5788b {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx;
}

/* 按钮样式 */
.btn.data-v-b5c5788b {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  transition: all 0.3s;
  border: none;
  outline: none;
}
.btn.data-v-b5c5788b:active {
  opacity: 0.8;
  transform: scale(0.98);
}
.btn.btn-primary.data-v-b5c5788b {
  background: linear-gradient(135deg, #FF6B9D, #FF69B4);
  color: #FFFFFF;
}
.btn.btn-secondary.data-v-b5c5788b {
  background: #F2F2F2;
  color: #333333;
}
.btn.btn-outline.data-v-b5c5788b {
  border: 2rpx solid #FF6B9D;
  color: #FF6B9D;
  background: transparent;
}
.btn.btn-disabled.data-v-b5c5788b {
  opacity: 0.5;
  pointer-events: none;
}

/* 输入框样式 */
.input.data-v-b5c5788b {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1px solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: #FFFFFF;
}
.input.data-v-b5c5788b:focus {
  border-color: #FF6B9D;
}
.input.input-error.data-v-b5c5788b {
  border-color: #f5222d;
}

/* 分隔线 */
.divider.data-v-b5c5788b {
  height: 1rpx;
  background: #E5E5E5;
  margin: 24rpx 0;
}

/* 徽章 */
.badge.data-v-b5c5788b {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
