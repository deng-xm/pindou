  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 18rpx;
}

/* 加载动画 */
@keyframes spin-b5c5788b {
from {
    transform: rotate(0deg);
}
to {
    transform: rotate(360deg);
}
}
.loading-spinner.data-v-b5c5788b {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid rgba(255, 107, 157, 0.3);
  border-top-color: #FF6B9D;
  border-radius: 50%;
  animation: spin-b5c5788b 0.8s linear infinite;
}

