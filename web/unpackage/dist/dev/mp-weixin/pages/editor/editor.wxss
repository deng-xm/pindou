  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 18rpx;
}

/* 加载动画 */
@keyframes spin-17f547cb {
from {
    transform: rotate(0deg);
}
to {
    transform: rotate(360deg);
}
}
.loading-spinner.data-v-17f547cb {
