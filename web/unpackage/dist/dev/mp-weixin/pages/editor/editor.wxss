}

/* 分隔线 */
.divider.data-v-17f547cb {
  height: 1rpx;
  background: #E5E5E5;
  margin: 24rpx 0;
}

/* 徽章 */
.badge.data-v-17f547cb {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
